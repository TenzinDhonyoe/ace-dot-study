---
// Landing page. Quiet / editorial voice — the first paragraph sets the
// tone for the whole product. The upload flow and the generating UI live
// on this same page (no navigation) so the SSE connection stays attached
// through the full 60-180s generation. Once complete, we redirect to the
// rendered site at /<slug>.
import "~/styles/tokens.css";

const turnstileSiteKey = (
  import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? ""
).trim();
const turnstileEnabled = turnstileSiteKey.length > 0;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ace.study — lecture PDFs → interactive study site</title>
    <meta
      name="description"
      content="Drop three lecture PDFs. Get back an interactive study site in 90 seconds. No account. Link-shareable."
    />
    <meta property="og:title" content="ace.study" />
    <meta
      property="og:description"
      content="Lecture PDFs in, interactive study site out. 90 seconds. No account."
    />
    <meta property="og:type" content="website" />
    {turnstileEnabled && (
      <script
        is:inline
        src="https://challenges.cloudflare.com/turnstile/v0/api.js"
        async
        defer></script>
    )}
    <style>
      .wrap {
        max-width: min(94vw, 880px);
        margin: 0 auto;
        padding: calc(var(--rhythm) * 1.5) clamp(18px, 5vw, 48px)
          calc(var(--rhythm) * 4);
      }
      .wordmark {
        font-family: var(--sans);
        font-weight: 600;
        font-size: 15px;
        letter-spacing: -0.01em;
        color: var(--ink);
        margin: 0 0 calc(var(--rhythm) * 2);
      }
      .lede {
        font-size: clamp(20px, 1vw + 15px, 26px);
        line-height: 1.4;
        letter-spacing: -0.005em;
        margin: 0 0 var(--rhythm);
        max-width: 34ch; /* keep paragraph readable even in wider container */
      }
      .drop {
        border: 1.5px dashed var(--rule);
        border-radius: 10px;
        padding: clamp(32px, 8vw, 56px) 20px;
        text-align: center;
        font-family: var(--sans);
        font-size: 15px;
        color: var(--muted);
        background: transparent;
        width: 100%;
        cursor: pointer;
        transition:
          border-color 0.15s ease,
          color 0.15s ease,
          background 0.15s ease;
      }
      .drop:hover,
      .drop:focus-visible,
      .drop.is-drag {
        border-color: var(--accent);
        color: var(--ink);
        background: var(--accent-soft);
        outline: none;
      }
      .drop[disabled] {
        opacity: 0.5;
        cursor: default;
      }
      .filelist {
        margin: calc(var(--rhythm) / 2) 0 0;
        padding: 0;
        list-style: none;
        font-family: var(--sans);
        font-size: 13.5px;
        color: var(--muted);
      }
      .filelist li {
        padding: 2px 0;
      }

      /* --- Meta-context form --- */
      .form {
        margin-top: var(--rhythm);
        display: none;
      }
      .form.visible {
        display: block;
      }
      .field {
        margin: 0 0 var(--rhythm);
      }
      .field label {
        display: block;
        font-family: var(--sans);
        font-size: 13px;
        color: var(--muted);
        margin: 0 0 calc(var(--rhythm) / 2);
        letter-spacing: 0.01em;
      }
      .field input[type="text"],
      .field input[type="date"],
      .field input[type="password"],
      .field textarea {
        width: 100%;
        background: transparent;
        color: var(--ink);
        font-family: var(--serif);
        font-size: 16px;
        line-height: 1.5;
        border: none;
        border-bottom: 1px solid var(--rule);
        border-radius: 0;
        padding: 4px 0 6px;
        outline: none;
        transition: border-color 0.15s ease;
      }
      .field input:focus,
      .field textarea:focus {
        border-bottom-color: var(--accent);
      }
      .field textarea {
        resize: vertical;
        min-height: calc(var(--rhythm) * 3);
      }
      .pills {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }
      .pill {
        font-family: var(--sans);
        font-size: 13.5px;
        color: var(--muted);
        background: transparent;
        border: 1px solid var(--rule);
        border-radius: 999px;
        padding: 6px 14px;
        cursor: pointer;
        transition:
          border-color 0.15s ease,
          color 0.15s ease,
          background 0.15s ease;
      }
      .pill:hover {
        color: var(--ink);
        border-color: var(--ink);
      }
      .pill.is-selected {
        color: var(--accent);
        background: var(--accent-soft);
        border-color: var(--accent);
      }
      .more-toggle {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: transparent;
        border: none;
        padding: 0;
        font-family: var(--sans);
        font-size: 13.5px;
        color: var(--muted);
        cursor: pointer;
        margin: 0 0 var(--rhythm);
      }
      .more-toggle:hover {
        color: var(--accent);
      }
      .more-toggle .chev {
        transition: transform 0.15s ease;
      }
      .more-toggle[aria-expanded="true"] .chev {
        transform: rotate(90deg);
      }
      .more {
        display: none;
      }
      .more.is-open {
        display: block;
      }

      .generate {
        display: block;
        width: 100%;
        margin-top: var(--rhythm);
        font-family: var(--sans);
        font-size: 15px;
        font-weight: 600;
        color: var(--paper);
        background: var(--ink);
        border: none;
        border-radius: 8px;
        padding: 14px 20px;
        cursor: pointer;
      }
      .generate:hover {
        background: var(--accent);
      }
      .generate[disabled] {
        opacity: 0.4;
        cursor: default;
      }
      .example {
        margin: calc(var(--rhythm) * 2) 0 0;
        font-family: var(--sans);
        font-size: 13.5px;
        color: var(--muted);
      }
      .foot {
        margin: calc(var(--rhythm) * 3) 0 0;
        font-family: var(--sans);
        font-size: 12.5px;
        color: var(--muted);
      }

      /* Generation focus overlay (Lovable-style).
         Fixed, full-viewport, blurs the landing underneath. Shows just the
         URL + progress bar + one sentence of what the model is doing now.
         No narration stream dump — one sentence at a time, replaces smoothly. */
      .overlay {
        position: fixed;
        inset: 0;
        z-index: 100;
        display: none;
        align-items: center;
        justify-content: center;
        padding: clamp(16px, 4vw, 32px);
        background: color-mix(in oklab, var(--paper) 55%, transparent);
        backdrop-filter: blur(18px) saturate(140%);
        -webkit-backdrop-filter: blur(18px) saturate(140%);
        animation: overlay-in 0.3s ease;
      }
      .overlay.visible {
        display: flex;
      }
      @keyframes overlay-in {
        from {
          opacity: 0;
          backdrop-filter: blur(0);
        }
        to {
          opacity: 1;
        }
      }
      .card {
        width: min(100%, 520px);
        background: var(--paper);
        border: 1px solid var(--rule);
        border-radius: 14px;
        padding: clamp(24px, 4vw, 36px);
        box-shadow: 0 30px 80px rgba(0, 0, 0, 0.18);
        font-family: var(--sans);
      }
      .card__url {
        font-size: 12.5px;
        color: var(--muted);
        margin: 0 0 6px;
        letter-spacing: 0.02em;
      }
      .card__url-val {
        display: flex;
        align-items: center;
        gap: 8px;
        margin: 0 0 calc(var(--rhythm) * 1.2);
      }
      .card__url-val .url {
        font-family: var(--mono);
        font-size: 14px;
        color: var(--ink);
        background: var(--accent-soft);
        padding: 3px 8px;
        border-radius: 5px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        flex: 1;
        min-width: 0;
      }
      .card__url-val .copy {
        background: transparent;
        border: 1px solid var(--rule);
        border-radius: 6px;
        width: 34px;
        height: 34px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: var(--muted);
        flex-shrink: 0;
      }
      .card__url-val .copy:hover {
        color: var(--ink);
        border-color: var(--ink);
      }
      .bar {
        height: 4px;
        background: var(--rule);
        border-radius: 2px;
        overflow: hidden;
        margin: 0 0 10px;
      }
      .bar__fill {
        height: 100%;
        width: 0%;
        background: var(--accent);
        transition:
          width 0.4s ease,
          background 0.3s ease;
      }
      .bar__fill.is-indeterminate {
        width: 30% !important;
        background: linear-gradient(
          90deg,
          transparent,
          var(--accent),
          transparent
        );
        animation: slide 1.4s ease-in-out infinite;
      }
      @keyframes slide {
        0% {
          transform: translateX(-100%);
        }
        100% {
          transform: translateX(333%);
        }
      }
      .card__stage {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 12px;
        font-size: 12px;
        color: var(--muted);
        letter-spacing: 0.06em;
        text-transform: uppercase;
        margin: 0 0 calc(var(--rhythm) * 0.8);
      }
      .card__stage .pct {
        letter-spacing: 0;
        text-transform: none;
        font-variant-numeric: tabular-nums;
      }
      .card__sentence {
        font-family: var(--serif);
        font-size: 17px;
        line-height: 1.45;
        color: var(--ink);
        min-height: 3em; /* reserve 2 lines so bar doesn't jump */
        margin: 0 0 calc(var(--rhythm) * 1.2);
        transition: opacity 0.25s ease;
      }
      .card__sentence.is-changing {
        opacity: 0.3;
      }
      .card__cancel {
        background: transparent;
        border: none;
        padding: 0;
        font-family: var(--sans);
        font-size: 13.5px;
        color: var(--muted);
        cursor: pointer;
      }
      .card__cancel:hover {
        color: var(--warn);
        text-decoration: underline;
      }

      .error {
        font-family: var(--sans);
        font-size: 14px;
        color: var(--warn);
        background: color-mix(in oklab, var(--warn) 8%, transparent);
        border: 1px solid var(--warn);
        border-radius: 6px;
        padding: 12px 14px;
        margin-top: var(--rhythm);
      }
      .hidden {
        display: none !important;
      }
    </style>
  </head>
  <body>
    <main class="wrap">
      <p class="wordmark">ace.study</p>

      <!-- Upload view -->
      <section id="uploadView">
        <p class="lede">
          Drop three lecture PDFs. Get back an interactive study site in 90
          seconds. No account. Link-shareable.
        </p>

        <button
          class="drop"
          id="uploadBtn"
          type="button"
          aria-label="Add lecture PDFs"
        >
          Tap to add PDFs
        </button>
        <ul class="filelist" id="fileList"></ul>

        <input
          type="file"
          id="fileInput"
          accept="application/pdf,.pdf"
          multiple
          hidden
        />

        <div class="form" id="metaForm">
          <div class="field">
            <label for="fCourse">Course</label>
            <input
              type="text"
              id="fCourse"
              name="course"
              placeholder="e.g. BME 804 Biomedical Instrumentation"
              autocomplete="off"
              maxlength="120"
            />
          </div>

          <div class="field">
            <label for="fExamDate">Exam date</label>
            <input type="date" id="fExamDate" name="examDate" />
          </div>

          <div class="field">
            <label>Exam format</label>
            <div class="pills" role="radiogroup" aria-label="Exam format" id="formatPills">
              <button type="button" class="pill" data-value="mcq-heavy" role="radio" aria-checked="false">MCQ-heavy</button>
              <button type="button" class="pill" data-value="problem-sets" role="radio" aria-checked="false">Problem sets</button>
              <button type="button" class="pill is-selected" data-value="mixed" role="radio" aria-checked="true">Mixed</button>
              <button type="button" class="pill" data-value="essay" role="radio" aria-checked="false">Essay</button>
            </div>
          </div>

          <button
            type="button"
            class="more-toggle"
            id="moreToggle"
            aria-expanded="false"
            aria-controls="moreFields"
          >
            <span class="chev" aria-hidden="true">›</span>
            <span>More context</span>
          </button>

          <div class="more" id="moreFields">
            <div class="field">
              <label for="fFocus">Focus areas</label>
              <textarea
                id="fFocus"
                name="focusAreas"
                placeholder="Anything specific worth prioritizing? e.g. 'Microactuators and biosensors; skip the intro lectures.'"
                rows="3"
                maxlength="500"
              ></textarea>
            </div>

            <div class="field">
              <label for="fKey">Anthropic API key <span style="opacity:0.7">(optional — skips rate limit)</span></label>
              <input
                type="password"
                id="fKey"
                name="anthropicKey"
                placeholder="sk-ant-..."
                autocomplete="off"
                spellcheck="false"
              />
            </div>
          </div>
        </div>

        {turnstileEnabled && (
          <div
            class="cf-turnstile"
            data-sitekey={turnstileSiteKey}
            data-size="invisible"
            id="turnstileWidget"
          >
          </div>
        )}

        <button
          class="generate hidden"
          id="generateBtn"
          type="button"
          disabled
        >
          Generate
        </button>

        <p class="example">
          See an example: <em>(coming soon)</em>
        </p>

        <p class="foot">
          Open source on
          <a href="https://github.com/TenzinDhonyoe/ace">GitHub</a>.
        </p>
      </section>

    </main>

    <!-- Generation focus overlay. Appears on top of the landing with a
         blurred backdrop; shows URL, progress bar, a single rolling
         sentence, and cancel. No narration stream dump. -->
    <div
      class="overlay"
      id="overlay"
      role="dialog"
      aria-modal="true"
      aria-labelledby="cardStage"
    >
      <div class="card">
        <p class="card__url">Your site will live at</p>
        <div class="card__url-val">
          <span class="url" id="genUrl">ace.study/—</span>
          <button
            class="copy"
            id="copyBtn"
            type="button"
            aria-label="Copy URL"
          >⧉</button>
        </div>

        <div class="bar">
          <div
            class="bar__fill is-indeterminate"
            id="barFill"
            role="progressbar"
            aria-valuemin="0"
            aria-valuemax="100"
            aria-label="Generation progress"
          >
          </div>
        </div>

        <div class="card__stage">
          <span id="stageLabel">Preparing…</span>
          <span class="pct" id="stagePct"></span>
        </div>

        <p class="card__sentence" id="cardSentence" aria-live="polite">
          Reading lecture material.
        </p>

        <button type="button" class="card__cancel" id="cancelBtn">
          Cancel
        </button>

        <div id="errorBox" class="error hidden"></div>
      </div>
    </div>

    <script>
      import { extractPdfs } from "~/lib/pdf-extract";
      import { consumeGenerateStream } from "~/lib/sse-client";

      const uploadBtn = document.getElementById(
        "uploadBtn",
      ) as HTMLButtonElement;
      const fileInput = document.getElementById(
        "fileInput",
      ) as HTMLInputElement;
      const fileList = document.getElementById("fileList") as HTMLUListElement;
      const generateBtn = document.getElementById(
        "generateBtn",
      ) as HTMLButtonElement;
      const uploadView = document.getElementById(
        "uploadView",
      ) as HTMLElement;
      const overlay = document.getElementById("overlay") as HTMLDivElement;
      const genUrl = document.getElementById("genUrl") as HTMLSpanElement;
      const copyBtn = document.getElementById("copyBtn") as HTMLButtonElement;
      const cancelBtn = document.getElementById(
        "cancelBtn",
      ) as HTMLButtonElement;
      const sentenceEl = document.getElementById(
        "cardSentence",
      ) as HTMLParagraphElement;
      const errorBox = document.getElementById("errorBox") as HTMLDivElement;
      const stageLabel = document.getElementById(
        "stageLabel",
      ) as HTMLSpanElement;
      const stagePct = document.getElementById(
        "stagePct",
      ) as HTMLSpanElement;
      const barFill = document.getElementById("barFill") as HTMLDivElement;

      const STAGE_COPY: Record<string, string> = {
        reading: "Reading lecture material",
        composing: "Composing study site",
        rendering: "Rendering HTML",
        storing: "Publishing",
        done: "Done",
      };
      // Rough weights so the bar moves even outside the composing stage.
      // Composing is by far the longest (60-120s of model work), so it
      // takes the lion's share of the bar.
      const STAGE_BASE: Record<string, number> = {
        reading: 2,
        composing: 5, // composing fills 5-90 based on tokens
        rendering: 92,
        storing: 96,
        done: 100,
      };
      const STAGE_COMPOSING_CEIL = 90;

      let picked: File[] = [];
      let abortCtrl: AbortController | null = null;

      uploadBtn.addEventListener("click", () => fileInput.click());

      // Drag-drop
      uploadBtn.addEventListener("dragover", (e) => {
        e.preventDefault();
        uploadBtn.classList.add("is-drag");
      });
      uploadBtn.addEventListener("dragleave", () =>
        uploadBtn.classList.remove("is-drag"),
      );
      uploadBtn.addEventListener("drop", (e) => {
        e.preventDefault();
        uploadBtn.classList.remove("is-drag");
        const files = Array.from(e.dataTransfer?.files ?? []).filter((f) =>
          f.name.toLowerCase().endsWith(".pdf"),
        );
        handlePicked(files);
      });

      fileInput.addEventListener("change", () => {
        const files = Array.from(fileInput.files ?? []);
        handlePicked(files);
      });

      function handlePicked(files: File[]) {
        if (!files.length) return;
        picked = files;
        fileList.innerHTML = files
          .map((f) => `<li>${escapeHtml(f.name)} (${kb(f.size)} KB)</li>`)
          .join("");
        // Reveal the meta-context form + Generate button together so the
        // user sees the full next-steps surface once they've committed
        // to a file set.
        document.getElementById("metaForm")!.classList.add("visible");
        generateBtn.classList.remove("hidden");
        generateBtn.disabled = false;
      }

      // Radio-pill behavior for Exam format
      const formatPills = document.getElementById("formatPills")!;
      let examFormat: string = "mixed";
      formatPills.addEventListener("click", (e) => {
        const btn = (e.target as HTMLElement).closest<HTMLButtonElement>(
          ".pill",
        );
        if (!btn) return;
        examFormat = btn.dataset.value ?? "mixed";
        formatPills.querySelectorAll<HTMLButtonElement>(".pill").forEach(
          (b) => {
            const on = b === btn;
            b.classList.toggle("is-selected", on);
            b.setAttribute("aria-checked", String(on));
          },
        );
      });

      // "More context" expando
      const moreToggle = document.getElementById(
        "moreToggle",
      ) as HTMLButtonElement;
      const moreFields = document.getElementById("moreFields") as HTMLDivElement;
      moreToggle.addEventListener("click", () => {
        const open = moreFields.classList.toggle("is-open");
        moreToggle.setAttribute("aria-expanded", String(open));
      });

      window.addEventListener("unhandledrejection", (e) => {
        console.error("[unhandled]", e.reason);
        showError(
          `Uncaught error: ${e.reason?.message ?? String(e.reason)}. Check browser console for details.`,
        );
      });

      generateBtn.addEventListener("click", async () => {
        generateBtn.disabled = true;
        generateBtn.textContent = "Reading PDFs…";

        // 1. Extract text from PDFs (client-side, pdf.js). 60s timeout so
        //    a worker failure becomes visible instead of a silent hang.
        let pdfText: string;
        try {
          const extractWithTimeout = Promise.race([
            extractPdfs(picked),
            new Promise<never>((_, reject) =>
              setTimeout(
                () =>
                  reject(
                    new Error(
                      "PDF extraction timed out after 60s (worker may have failed to load)",
                    ),
                  ),
                60_000,
              ),
            ),
          ]);
          const ex = await extractWithTimeout;
          pdfText = ex.text;
          console.log("[gen] extracted", pdfText.length, "chars");
        } catch (e) {
          showError(
            `Couldn't read the PDF: ${(e as Error).message}. If it's encrypted, remove the password and try again.`,
          );
          return;
        }

        // 2. Get a Turnstile token
        const turnstileToken = await getTurnstileToken();
        if (!turnstileToken) {
          showError("Captcha didn't verify. Refresh and try again.");
          return;
        }

        // 3. Show the focus overlay (landing stays visible + blurred behind)
        overlay.classList.add("visible");
        sentenceEl.textContent = "Reading lecture material.";

        // 4. Collect form values + POST
        const course = (
          document.getElementById("fCourse") as HTMLInputElement
        ).value.trim();
        const examDate = (
          document.getElementById("fExamDate") as HTMLInputElement
        ).value.trim();
        const focusAreas = (
          document.getElementById("fFocus") as HTMLTextAreaElement
        ).value.trim().slice(0, 500);
        const apiKey = (
          document.getElementById("fKey") as HTMLInputElement
        ).value.trim();

        const meta: Record<string, string> = {};
        if (course) meta.course = course;
        if (examDate) meta.examDate = examDate;
        if (examFormat) meta.examFormat = examFormat;
        if (focusAreas) meta.focusAreas = focusAreas;

        const headers: Record<string, string> = {
          "Content-Type": "application/json",
        };
        if (apiKey) headers["X-Anthropic-Key"] = apiKey;

        // Abort handle so the Cancel button can bail mid-stream
        abortCtrl = new AbortController();
        const res = await fetch("/api/generate", {
          method: "POST",
          headers,
          body: JSON.stringify({ pdfText, meta, turnstileToken }),
          signal: abortCtrl.signal,
        });

        let slug: string | null = null;

        try {
          for await (const event of consumeGenerateStream(res)) {
            switch (event.type) {
              case "slug":
                slug = event.slug;
                genUrl.textContent = `${location.host}/${slug}`;
                history.replaceState(null, "", `/g/${slug}`);
                break;
              case "progress":
                handleProgress(event);
                break;
              case "narration":
                showLatestSentence(event.text);
                break;
              case "complete":
                if (event.slug) {
                  setTimeout(() => {
                    location.href = `/${event.slug}`;
                  }, 600);
                }
                break;
              case "error":
                showError(event.message);
                break;
            }
          }
        } catch (e) {
          // User-initiated abort isn't an error worth flagging
          if ((e as Error).name !== "AbortError") {
            showError(`Stream disconnected: ${(e as Error).message}`);
          }
        }

        function handleProgress(event: {
          stage: string;
          tokensOut?: number;
          estMaxTokens?: number;
        }) {
          const base = STAGE_BASE[event.stage] ?? 0;
          const copy = STAGE_COPY[event.stage] ?? event.stage;
          stageLabel.textContent = copy;

          let pct: number;
          if (
            event.stage === "composing" &&
            event.tokensOut !== undefined &&
            event.estMaxTokens
          ) {
            // Map token progress into the 5–90 span of the bar
            const ratio = Math.min(1, event.tokensOut / event.estMaxTokens);
            pct = base + (STAGE_COMPOSING_CEIL - base) * ratio;
            // Real data — drop the indeterminate shimmer
            barFill.classList.remove("is-indeterminate");
          } else {
            pct = base;
            // Reading / rendering / storing have no token signal;
            // show an indeterminate shimmer so the bar feels alive
            if (event.stage !== "composing") {
              barFill.classList.add("is-indeterminate");
            }
          }

          // For determinate stages we set width; indeterminate ignores width
          barFill.style.width = `${pct.toFixed(1)}%`;
          barFill.setAttribute("aria-valuenow", String(Math.round(pct)));

          // Show a % only once we're in the composing stage with real data
          if (
            event.stage === "composing" &&
            event.tokensOut !== undefined &&
            event.estMaxTokens
          ) {
            stagePct.textContent = `${Math.round(pct)}%`;
          } else if (event.stage === "done") {
            stagePct.textContent = "100%";
          } else {
            stagePct.textContent = "";
          }
        }
      });

      copyBtn.addEventListener("click", () => {
        navigator.clipboard.writeText(genUrl.textContent || "");
        copyBtn.textContent = "✓";
        setTimeout(() => (copyBtn.textContent = "⧉"), 1500);
      });

      // Accumulates narration chunks into a running buffer and extracts
      // the LAST complete sentence. Only that sentence is shown on the
      // card — no scrollback, no stream dump. If the model's last full
      // sentence hasn't changed, we leave the UI alone (avoids jitter
      // during token-level streaming).
      let narrationBuffer = "";
      let currentSentence = "";
      function showLatestSentence(chunk: string) {
        narrationBuffer += chunk;
        const latest = lastCompleteSentence(narrationBuffer);
        if (!latest || latest === currentSentence) return;
        currentSentence = latest;
        // Smooth swap: dim → replace → restore
        sentenceEl.classList.add("is-changing");
        setTimeout(() => {
          sentenceEl.textContent = latest;
          sentenceEl.classList.remove("is-changing");
        }, 120);
      }

      function lastCompleteSentence(buf: string): string {
        // Walk backwards to the last sentence terminator. We only want
        // a *complete* sentence; partial fragments at the tail are dropped.
        const trimmed = buf.trim();
        if (!trimmed) return "";
        // Find the last terminator (., !, ?, or newline). The sentence
        // starts after the second-to-last terminator.
        const lastTerm = Math.max(
          trimmed.lastIndexOf("."),
          trimmed.lastIndexOf("!"),
          trimmed.lastIndexOf("?"),
          trimmed.lastIndexOf("\n"),
        );
        if (lastTerm === -1) return "";
        const upTo = trimmed.slice(0, lastTerm + 1);
        const priorTerm = Math.max(
          upTo.slice(0, -1).lastIndexOf("."),
          upTo.slice(0, -1).lastIndexOf("!"),
          upTo.slice(0, -1).lastIndexOf("?"),
          upTo.slice(0, -1).lastIndexOf("\n"),
        );
        const start = priorTerm === -1 ? 0 : priorTerm + 1;
        return upTo.slice(start).trim();
      }

      cancelBtn.addEventListener("click", () => {
        abortCtrl?.abort();
        overlay.classList.remove("visible");
        narrationBuffer = "";
        currentSentence = "";
        generateBtn.disabled = false;
        generateBtn.textContent = "Generate";
      });

      function showError(msg: string) {
        errorBox.textContent = msg;
        errorBox.classList.remove("hidden");
        generateBtn.disabled = false;
        generateBtn.textContent = "Try again";
      }

      async function getTurnstileToken(): Promise<string | null> {
        // If the Turnstile widget wasn't rendered (no site key configured),
        // the server-side verifier fails open. Send a placeholder so
        // /api/generate's "token missing" check passes.
        const widget = document.getElementById("turnstileWidget");
        if (!widget) return "no-turnstile-configured";

        const turnstile = (window as any).turnstile;
        if (!turnstile) return "no-turnstile-configured";

        return new Promise((resolve) => {
          const widgetId = turnstile.render("#turnstileWidget", {
            sitekey: widget.getAttribute("data-sitekey"),
            size: "invisible",
            callback: (token: string) => resolve(token),
            "error-callback": () => resolve(null),
          });
          turnstile.execute(widgetId);
        });
      }

      function kb(bytes: number): number {
        return Math.round(bytes / 1024);
      }
      function escapeHtml(s: string): string {
        return s
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;");
      }
    </script>
  </body>
</html>
