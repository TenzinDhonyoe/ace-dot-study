    "lint": "eslint . --ext .ts,.astro",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@astrojs/node": "^9.0.0",
    "@astrojs/vercel": "^8.0.0",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.3",
    "@vercel/blob": "^0.27.0",
    "ace-study-prompts": "^0.1.0",
    "ace-study-template": "^0.3.1",
    "astro": "^5.0.0",
    "nanoid": "^5.0.9",
    "pdfjs-dist": "^5.6.205"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "packageManager": "bun@1.3.10",
  "engines": {
    "node": ">=20"
