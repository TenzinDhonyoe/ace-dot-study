{
  "name": "ace-dot-study",
  "version": "0.0.1",
  "private": true,
  "description": "Hosted ace.study — upload lecture PDFs, get back an interactive study site. Phase 2 of Ace.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
