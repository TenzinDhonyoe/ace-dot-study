# Anthropic API key used for the shared house generator. BYOK users pass
# their own key via an X-Anthropic-Key header; their key never hits this env.
ANTHROPIC_API_KEY=sk-ant-xxx

# Upstash Redis — used for per-IP rate-limiting AND the atomic daily spend
# counter. Get these from https://console.upstash.com after creating a
# Redis database. Vercel KV auto-populates equivalent vars at deploy time.
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# Vercel Blob — R2-equivalent. Auto-populated by Vercel at deploy time;
# set locally for `astro dev` against a real bucket.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# Cloudflare Turnstile — invisible CAPTCHA on /api/generate. Get both from
# https://dash.cloudflare.com → Turnstile.
PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAAxxx
TURNSTILE_SECRET_KEY=0x4AAAAAAAxxx

# Spend-cap limits (tune based on your Anthropic budget).
# $100/mo budget at ~$0.50/generation = ~200 successful generations/mo.
# Cap the DAILY spend to leave headroom for bursts. $3/day = $90/mo ceiling.
MAX_DAILY_ANTHROPIC_USD=3
MAX_GENERATIONS_PER_IP_PER_DAY=3

# Base URL — set to your Vercel preview or production URL.
PUBLIC_SITE_URL=http://localhost:4321
